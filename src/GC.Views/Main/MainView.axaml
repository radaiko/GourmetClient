<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:GC.ViewModels;assembly=GC.ViewModels"
             x:Class="GC.Views.Main.MainView"
             x:DataType="viewModels:MainViewModel">
  <Grid RowDefinitions="Auto, *" ColumnDefinitions="*">
    <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
      <TextBlock Text="Gourmet" FontWeight="Bold" FontSize="20" />
      <TextBlock Text=" - Desktop/Mobile shared view" Margin="8,0,0,0"/>
    </StackPanel>

    <ContentControl Grid.Row="1" Content="{Binding}"/>
  </Grid>
</UserControl>
