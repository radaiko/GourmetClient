<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="GourmetClient.Maui.Views.MenuOrderView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:GourmetClient.Maui.Behaviors"
             xmlns:views="clr-namespace:GourmetClient.Maui.Views"
             xmlns:viewModels="clr-namespace:GourmetClient.ViewModels">

    <ContentView.Resources>
        <behaviors:BoolInvertConverter x:Key="BoolInvertConverter" />
        <behaviors:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <behaviors:AllergensToStringConverter x:Key="AllergensToStringConverter" />

        <Color x:Key="ActionBarBackground">#F2F2F2</Color>
        <Color x:Key="DayBackground">#F2F2F2</Color>
    </ContentView.Resources>

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Action Bar -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource ActionBarBackground}" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackLayout Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="ShowBillButton"
                            Text="📋"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Clicked="OnShowBillButtonClicked"
                            ToolTipProperties.Text="Show Bill" />

                    <Button Text="🔄"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Command="{Binding UpdateMenuCommand}"
                            ToolTipProperties.Text="Refresh Menu" />

                    <Button Text="✅"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Command="{Binding ExecuteSelectedOrderCommand}"
                            ToolTipProperties.Text="Execute Order" />
                </StackLayout>

                <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="AboutButton"
                            Text="ℹ️"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Clicked="OnAboutButtonClicked"
                            ToolTipProperties.Text="About" />
                    <Button x:Name="SettingsButton"
                            Text="⚙️"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Clicked="OnSettingsButtonClicked"
                            ToolTipProperties.Text="Settings" />
                </StackLayout>
            </Grid>
        </Border>

        <!-- Notifications -->
        <Border Grid.Row="1" Padding="5">
            <ScrollView MaximumHeightRequest="100">
                <views:NotificationsView />
            </ScrollView>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <!-- Menu Content -->
            <Grid IsVisible="{Binding ShowWelcomeMessage, Converter={StaticResource BoolInvertConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Category Headers -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BackgroundColor="{StaticResource DayBackground}" />

                    <CollectionView Grid.Column="1" ItemsSource="{Binding MenuCategories}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{StaticResource DayBackground}"
                                        MinimumWidthRequest="150"
                                        Padding="12,0,0,0"
                                        Stroke="{StaticResource DayBackground}"
                                        StrokeThickness="2,0,0,0">
                                    <Label VerticalOptions="Center" FontSize="20">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding .}" Value="0">
                                                <Setter Property="Text" Value="Menü 1" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding .}" Value="1">
                                                <Setter Property="Text" Value="Menü 2" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding .}" Value="2">
                                                <Setter Property="Text" Value="Menü 3" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding .}" Value="3">
                                                <Setter Property="Text" Value="Suppe &amp; Salat" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- Menu Days -->
                <ScrollView x:Name="MenuScrollViewer"
                           Grid.Row="1"
                           VerticalScrollBarVisibility="Always"
                           Scrolled="OnMenuScrollViewerScrollChanged">
                    <CollectionView ItemsSource="{Binding MenuDays}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:GourmetMenuDayViewModel">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BackgroundColor="{StaticResource DayBackground}">
                                        <StackLayout Margin="10" VerticalOptions="Center">
                                            <Label FontSize="26" Text="{Binding Date, StringFormat='{0:dd.MM}'}" />
                                            <Label FontSize="14" Text="{Binding Date, StringFormat='{0:dddd}'}" />
                                        </StackLayout>
                                    </Border>

                                    <CollectionView Grid.Column="1" ItemsSource="{Binding Menus}">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" />
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:GourmetMenuViewModel">
                                                <Border BackgroundColor="White"
                                                        Stroke="{StaticResource DayBackground}"
                                                        StrokeThickness="0,2"
                                                        MinimumWidthRequest="150"
                                                        HeightRequest="120"
                                                        Margin="0,-2">
                                                    <Grid>
                                                        <Border Width="2"
                                                                Margin="0,-2"
                                                                BackgroundColor="{StaticResource DayBackground}"
                                                                HorizontalOptions="Start" />
                                                        <Grid Margin="10,0">
                                                            <Grid.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type views:MenuOrderView}}, Path=BindingContext.ToggleMenuOrderedMarkCommand}"
                                                                                      CommandParameter="{Binding .}" />
                                                            </Grid.GestureRecognizers>
                                                            <Grid Margin="0,10,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="*" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Label Grid.Row="0" Grid.Column="0"
                                                                       FontSize="14"
                                                                       Text="{Binding MenuDescription}"
                                                                       LineBreakMode="TailTruncation"
                                                                       MaxLines="3"
                                                                       VerticalOptions="Start"
                                                                       HorizontalOptions="Start"
                                                                       TextColor="Black" />

                                                                <Label Grid.Row="1" Grid.Column="0"
                                                                       Margin="0,5,0,0"
                                                                       FontAttributes="Italic"
                                                                       Text="{Binding Allergens, Converter={StaticResource AllergensToStringConverter}}"
                                                                       HorizontalOptions="Start"
                                                                       TextColor="Gray" />

                                                                <StackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                                             Margin="5,0" Orientation="Vertical">
                                                                    <Label FontSize="16" HorizontalOptions="Center">
                                                                        <Label.Triggers>
                                                                            <DataTrigger TargetType="Label" Binding="{Binding MenuState}" Value="0">
                                                                                <Setter Property="IsVisible" Value="False" />
                                                                            </DataTrigger>
                                                                            <DataTrigger TargetType="Label" Binding="{Binding MenuState}" Value="1">
                                                                                <Setter Property="Text" Value="❌" />
                                                                                <Setter Property="IsVisible" Value="True" />
                                                                            </DataTrigger>
                                                                            <DataTrigger TargetType="Label" Binding="{Binding MenuState}" Value="2">
                                                                                <Setter Property="Text" Value="➕" />
                                                                                <Setter Property="IsVisible" Value="True" />
                                                                            </DataTrigger>
                                                                            <DataTrigger TargetType="Label" Binding="{Binding MenuState}" Value="3">
                                                                                <Setter Property="Text" Value="➖" />
                                                                                <Setter Property="IsVisible" Value="True" />
                                                                            </DataTrigger>
                                                                            <DataTrigger TargetType="Label" Binding="{Binding MenuState}" Value="4">
                                                                                <Setter Property="Text" Value="✅" />
                                                                                <Setter Property="IsVisible" Value="True" />
                                                                            </DataTrigger>
                                                                        </Label.Triggers>
                                                                    </Label>

                                                                    <Label FontSize="16"
                                                                           Text="⚠️"
                                                                           Margin="0,5,0,0"
                                                                           HorizontalOptions="Center"
                                                                           IsVisible="{Binding ShowWarning}" />
                                                                </StackLayout>
                                                            </Grid>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </Grid>

            <!-- Welcome Message -->
            <Grid IsVisible="{Binding ShowWelcomeMessage}">
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="Welcome to Gourmet Client! 🍽️"
                           FontSize="24"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Please configure your login settings first."
                           FontSize="18"
                           Margin="0,10,0,0"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Open Settings ⚙️"
                            Margin="0,20,0,0"
                            Clicked="OnSettingsButtonClicked"
                            HorizontalOptions="Center" />
                </StackLayout>
            </Grid>

            <!-- Loading Overlay -->
            <Grid IsVisible="{Binding IsMenuUpdating}" BackgroundColor="#80000000">
                <views:LoadingSpinner WidthRequest="70" HeightRequest="70"
                                      HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="3" BackgroundColor="#F0F0F0" Padding="10,5">
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Label Text="{Binding NameOfUser, StringFormat='Logged in as: {0}'}"
                       IsVisible="{Binding NameOfUser, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Label Text="|" IsVisible="{Binding NameOfUser, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Label Text="{Binding LastMenuUpdate, StringFormat='Last update: {0:g}'}" />
            </StackLayout>
        </Grid>
    </Grid>
</ContentView>