<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="GourmetClient.Maui.Views.ReleaseNotesPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Release Notes">
    <ScrollView>
        <StackLayout Padding="20">
            <Label Text="Release Notes" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   Margin="0,0,0,20" />
            
            <Label Text="Latest updates and improvements to the application."
                   FontSize="16"
                   Margin="0,0,0,10" />
            
            <!-- Add your release notes content here -->
            <Label Text="Version information will be displayed here based on your update service."
                   FontSize="14" />
        </StackLayout>
    </ScrollView>
</ContentPage>