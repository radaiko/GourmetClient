<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="GourmetClient.Maui.Views.DownloadUpdatePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Downloading Update">
    <StackLayout Padding="20">
        <Label Text="Downloading Update" 
               FontSize="24" 
               FontAttributes="Bold" 
               Margin="0,0,0,20" />
        
        <Label Text="Download Progress:"
               FontSize="16"
               Margin="0,0,0,10" />
               
        <ProgressBar Progress="{Binding DownloadProgress, Converter={StaticResource PercentageConverter}}"
                     Margin="0,0,0,10" />
                     
        <Label Text="{Binding DownloadProgress, StringFormat='{0}%'}"
               HorizontalOptions="Center"
               Margin="0,0,0,20" />
        
        <Button Text="Cancel"
                Command="{Binding CancelCommand}"
                HorizontalOptions="Center" />
    </StackLayout>
</ContentPage>