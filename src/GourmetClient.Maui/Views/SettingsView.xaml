<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="GourmetClient.Maui.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:GourmetClient.Maui.Behaviors"
             xmlns:viewModels="clr-namespace:GourmetClient.ViewModels">

    <ContentView.Resources>
        <behaviors:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="HeightRequest" Value="45" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BackgroundColor" Value="#2196F3" />
            <Setter Property="TextColor" Value="White" />
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="HeightRequest" Value="45" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BackgroundColor" Value="#6C757D" />
            <Setter Property="TextColor" Value="White" />
        </Style>

        <Style x:Key="GroupHeaderStyle" TargetType="Label">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#333" />
            <Setter Property="Margin" Value="10,10,10,5" />
        </Style>

        <Style x:Key="InputLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="#666" />
            <Setter Property="Margin" Value="10,5,5,5" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="InputStyle" TargetType="Entry">
            <Setter Property="Margin" Value="5,5,10,5" />
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="TextColor" Value="Black" />
        </Style>
    </ContentView.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" BackgroundColor="#F8F9FA" Padding="15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Label Grid.Column="0" 
                   Text="Settings" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" 
                   TextColor="#333" />
            
            <Button Grid.Column="1"
                    x:Name="CloseButton"
                    Text="X"
                    FontSize="16"
                    BackgroundColor="Transparent"
                    TextColor="#666"
                    Clicked="OnCloseButtonClicked"
                    WidthRequest="40"
                    HeightRequest="40" />
        </Grid>

        <!-- Settings Content -->
        <ScrollView Grid.Row="1">
            <StackLayout Orientation="Vertical" Spacing="0" Padding="0">
                
                <!-- Gourmet Section -->
                <Frame Margin="10,5" Padding="0" BackgroundColor="#F8F9FA" BorderColor="#E9ECEF">
                    <StackLayout>
                        <Label Text="Gourmet" Style="{StaticResource GroupHeaderStyle}" />
                        
                        <Grid Margin="10,0,10,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Benutzername:"
                                   Style="{StaticResource InputLabelStyle}" />
                            <Entry Grid.Row="0" Grid.Column="1"
                                   x:Name="LoginUsernameEntry"
                                   Text="{Binding LoginUsername}"
                                   Style="{StaticResource InputStyle}" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Passwort:"
                                   Style="{StaticResource InputLabelStyle}" />
                            <Entry Grid.Row="1" Grid.Column="1"
                                   x:Name="LoginPasswordEntry"
                                   IsPassword="True"
                                   Text="{Binding LoginPassword}"
                                   Style="{StaticResource InputStyle}" />
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- Ventopay Section -->
                <Frame Margin="10,5" Padding="0" BackgroundColor="#F8F9FA" BorderColor="#E9ECEF">
                    <StackLayout>
                        <Label Text="Ventopay" Style="{StaticResource GroupHeaderStyle}" />
                        
                        <Grid Margin="10,0,10,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Benutzername:"
                                   Style="{StaticResource InputLabelStyle}" />
                            <Entry Grid.Row="0" Grid.Column="1"
                                   x:Name="VentopayUsernameEntry"
                                   Text="{Binding VentopayUsername}"
                                   Style="{StaticResource InputStyle}" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Passwort:"
                                   Style="{StaticResource InputLabelStyle}" />
                            <Entry Grid.Row="1" Grid.Column="1"
                                   x:Name="VentopayPasswordEntry"
                                   IsPassword="True"
                                   Text="{Binding VentopayPassword}"
                                   Style="{StaticResource InputStyle}" />
                        </Grid>
                    </StackLayout>
                </Frame>

                <!-- Updates Section -->
                <Frame Margin="10,5" Padding="0" BackgroundColor="#F8F9FA" BorderColor="#E9ECEF">
                    <StackLayout>
                        <Label Text="Updates" Style="{StaticResource GroupHeaderStyle}" />
                        
                        <StackLayout Orientation="Vertical" Margin="10,0,10,10">
                            <StackLayout Orientation="Horizontal" Spacing="10">
                                <CheckBox x:Name="CheckForUpdatesCheckBox"
                                          IsChecked="{Binding CheckForUpdates}" />
                                <Label Text="Automatisch auf neue Versionen pr&#252;fen"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCheckForUpdatesLabelTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </StackLayout>

                            <Button x:Name="JoinPreReleaseButton"
                                    HorizontalOptions="Start"
                                    Margin="0,10,0,0"
                                    Command="{Binding JoinNextPreReleaseVersionCommand}"
                                    Text="Vorab-Version installieren"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    IsVisible="{Binding Command.CanExecute, Source={x:Reference JoinPreReleaseButton}, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackLayout>
                    </StackLayout>
                </Frame>
            </StackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" BackgroundColor="#F8F9FA" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1"
                    Command="{Binding SaveSettingsCommand}"
                    Text="&#220;bernehmen"
                    Style="{StaticResource SettingsButtonStyle}" />
                    
            <Button Grid.Column="2"
                    x:Name="CancelButton"
                    Text="Abbrechen"
                    Clicked="OnCancelButtonClicked"
                    Style="{StaticResource CloseButtonStyle}" />
        </Grid>
    </Grid>
</ContentView>